---
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import BaseLayout from '@/layouts/BaseLayout.astro';
import BodyExplorer from '@/components/react/BodyExplorer';
import { SYSTEMS } from '@/data/systems';
import { getExplorerParts } from '@/lib/graph';

const parts = await getExplorerParts();

// Resolve at build time which anatomical layers have a 3D model present, so the
// explorer can swap the model when you toggle layers.
const MODEL_FILES: Record<string, string> = {
  skeletal: 'body.glb',
  muscular: 'body-muscular.glb',
  organs: 'body-organs.glb',
  nervous: 'body-nervous.glb',
  cardiovascular: 'body-cardiovascular.glb',
  respiratory: 'body-respiratory.glb',
  digestive: 'body-digestive.glb',
  endocrine: 'body-endocrine.glb',
  integumentary: 'body-integumentary.glb',
};
const models: Record<string, string> = {};
for (const [sys, file] of Object.entries(MODEL_FILES)) {
  if (existsSync(fileURLToPath(new URL(`../../public/models/${file}`, import.meta.url)))) {
    models[sys] = `/models/${file}?v=hd`;
  }
}
const hasAnyModel = Object.keys(models).length > 0;

// FAQ content — short, factual, self-contained passages (35–60 words each)
// optimized for Generative Engine Optimization (AI search extractability).
const faqs = [
  {
    q: 'What is Materia?',
    a: 'Materia is an evidence-graded reference for remedies, organized by body part. A layered, clickable human body leads into a knowledge graph linking body, condition, remedy, compound, and study. Every remedy is evidence-graded and study-cited. It is ad-free and not medical advice.',
  },
  {
    q: 'Is Materia free?',
    a: 'Yes, Materia is completely free and ad-free. It is a static reference site with no subscription, no account, and no advertising. All content is publicly accessible to anyone, with nothing gated behind a paywall or sign-up.',
  },
  {
    q: 'How does Materia grade evidence?',
    a: 'Each remedy is assigned an evidence grade based on the quality and quantity of cited studies. Grades reflect the strength of clinical research, ranging from meta-analyses down to traditional use. The methodology page explains the full grading system in detail.',
  },
  {
    q: 'Can I search remedies by body part?',
    a: 'Yes. Materia features an interactive body explorer — click any anatomical region to see the conditions and remedies associated with that body part, from headaches to joint pain to digestive issues. The layered model lets you switch between skeletal, muscular, organ, and other systems.',
  },
  {
    q: 'Does Materia cover herbs, supplements, and drugs?',
    a: 'Yes. Materia covers all remedy types, including herbs, supplements, and pharmaceutical drugs. Each remedy is linked to its active compounds and the studies that tested it, regardless of whether the remedy is natural or synthetic. Coverage is judged by evidence, not category.',
  },
  {
    q: 'Is Materia medical advice?',
    a: 'No. Materia is not medical advice. It is an educational reference that compiles and grades the scientific evidence for remedies. Always consult a qualified healthcare professional before starting, stopping, or changing any treatment based on what you read here.',
  },
  {
    q: 'How many remedies does Materia have?',
    a: 'Materia includes hundreds of remedies across dozens of body parts and conditions, each with cited studies and an evidence grade. The content is hand-edited and continuously expanded as new research is reviewed and added to the knowledge graph.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
};

const softwareAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Materia',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web Browser',
  url: 'https://materia.significanthobbies.com',
  description:
    'An evidence-graded reference for remedies organized by body part. A layered, clickable human body leads into a knowledge graph of body, condition, remedy, compound, and study, with every remedy evidence-graded and study-cited.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  creator: {
    '@type': 'Person',
    name: 'Sarthak Agrawal',
    url: 'https://sarthakagrawal.dev',
  },
};

const jsonld = [faqJsonLd, softwareAppJsonLd];

const fleet = [
  { label: 'Foundry', href: 'https://sassmaker.com', note: 'SaaS factory floor' },
  { label: 'Aliveville', href: 'https://aliveville.com', note: 'AI world simulator' },
  { label: 'CodeVetter', href: 'https://codevetter.com', note: 'AI code review' },
  { label: 'High Signal', href: 'https://highsignal.app', note: 'Daily tech/startup brief' },
  { label: 'Karte', href: 'https://karte.cc', note: 'AI link-in-bio' },
  { label: 'RolePatch', href: 'https://rolepatch.com', note: 'AI resume tailoring' },
  { label: 'Significant Hobbies', href: 'https://significanthobbies.com', note: 'Hobby journey mapper' },
];
---

<BaseLayout jsonld={jsonld}>
  <section class="container-x grid items-center gap-10 py-16 lg:grid-cols-[1.05fr_1fr] lg:py-24">
    <div style="animation: rise 0.6s var(--ease-out-expo) both">
      <p class="eyebrow mb-4">Evidence-graded · Ad-free · Fully cited</p>
      <h1 class="text-4xl leading-[1.05] sm:text-5xl">
        The whole body,<br /><span class="text-accent">evidence-graded.</span>
      </h1>
      <p class="prose-materia mt-6 text-lg text-muted">
        Explore a layered human body, click any part, and see the herbs, supplements, and drugs
        that may help. Each one is graded by the strength of the research and linked to the studies
        behind it.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="#explorer"
          class="rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-strong"
          >Start exploring</a
        >
        <a
          href="/methodology"
          class="rounded-lg border border-line bg-surface px-5 py-2.5 text-sm font-medium text-fg transition-colors hover:border-line-strong"
          >How we grade evidence</a
        >
      </div>
    </div>

    <div id="explorer" style="animation: rise 0.7s var(--ease-out-expo) both; animation-delay: 0.08s">
      {
        hasAnyModel ? (
          <BodyExplorer client:only="react" parts={parts} models={models} />
        ) : (
          <BodyExplorer client:visible parts={parts} models={models} />
        )
      }
    </div>
  </section>

  <section class="container-x pb-8">
    <h2 class="eyebrow mb-4">Anatomical layers</h2>
    <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        SYSTEMS.map((s) => (
          <li class="card flex items-start gap-3 p-4">
            <span class="mt-0.5 h-2 w-2 shrink-0 rounded-full" style={`background:${s.available ? 'var(--color-accent)' : 'var(--color-grade-none)'}`} />
            <div>
              <p class="font-medium text-ink">
                {s.name}
                {!s.available && <span class="ml-2 text-[11px] font-normal text-faint">coming soon</span>}
              </p>
              <p class="mt-0.5 text-sm text-muted">{s.blurb}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="container-x py-16" aria-labelledby="faq-heading">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow mb-4">Frequently asked</p>
      <h2 id="faq-heading" class="text-3xl sm:text-4xl">Questions about Materia</h2>
      <div class="mt-8 divide-y divide-line border-y border-line">
        {
          faqs.map((f) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-ink">
                <span class="font-display text-lg font-medium leading-snug">{f.q}</span>
                <span
                  class="mt-1 shrink-0 text-faint transition-transform duration-200 group-open:rotate-45"
                  aria-hidden="true"
                >
                  +
                </span>
              </summary>
              <p class="prose-materia mt-3 text-muted">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container-x pb-16" aria-labelledby="fleet-heading">
    <div class="mx-auto max-w-3xl border-t border-line pt-10">
      <p class="eyebrow mb-4">More from the fleet</p>
      <h2 id="fleet-heading" class="text-lg text-ink" style="font-family: var(--font-display)">
        Sister projects by the same author
      </h2>
      <ul class="mt-5 grid gap-x-6 gap-y-2 sm:grid-cols-2">
        {
          fleet.map((f) => (
            <li class="flex items-baseline gap-2 text-sm text-muted">
              <a
                href={f.href}
                class="font-medium text-fg transition-colors hover:text-accent"
                rel="noopener"
                target="_blank"
              >
                {f.label}
              </a>
              <span class="text-faint">— {f.note}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
