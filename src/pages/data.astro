---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, getEntries } from 'astro:content';
import { site } from '@/data/site';

const [remedies, conditions, studies, compounds, sources, bodyParts] =
  await Promise.all([
    getCollection('remedies'),
    getCollection('conditions'),
    getCollection('studies'),
    getCollection('compounds'),
    getCollection('sources'),
    getCollection('bodyParts'),
  ]);

// Count efficacy edges (remedy×condition claims) and citation edges
let efficacyEdges = 0;
let studyCitations = 0;
let sourceCitations = 0;
let interactionEdges = 0;
let compoundEdges = 0;

for (const r of remedies) {
  efficacyEdges += r.data.efficacy.length;
  for (const c of r.data.efficacy) {
    studyCitations += c.studies.length;
    sourceCitations += c.sources.length;
  }
  interactionEdges += r.data.interactsWith.length;
  compoundEdges += r.data.compounds.length;
}

const totalNodes =
  remedies.length +
  conditions.length +
  studies.length +
  compounds.length +
  sources.length +
  bodyParts.length;
const totalEdges =
  efficacyEdges +
  studyCitations +
  sourceCitations +
  interactionEdges +
  compoundEdges +
  bodyParts.reduce((n, bp) => n + bp.data.conditions.length, 0);

const datasetJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'Materia Knowledge Graph',
  description:
    'Evidence-graded knowledge graph of remedy→condition→study relationships, exported from the Materia content collection. Every remedy×condition edge carries a letter grade (A–D / insufficient) and links to the studies and sources behind it.',
  url: `${site.url}/data/materia-graph.json`,
  inLanguage: 'en',
  creator: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  license: 'https://creativecommons.org/licenses/by/4.0/',
  isAccessibleForFree: true,
  keywords: [
    'evidence-based medicine',
    'herbal medicine',
    'supplements',
    'knowledge graph',
    'GRADE',
    'remedy interactions',
  ],
  distribution: {
    '@type': 'DataDownload',
    encodingFormat: 'application/json',
    contentUrl: `${site.url}/data/materia-graph.json`,
  },
  variableMeasured: [
    'remedy name, kind, aliases, summary',
    'condition name, aliases, severity, red flags',
    'study title, design, year, sample size, effect, PMID/DOI',
    'compound name, classification, mechanism, targets',
    'source title, publisher, URL',
    'body part name, region, anatomical systems',
    'efficacy grade (A/B/C/D/insufficient) per remedy×condition',
    'interaction severity (severe/moderate/minor/theoretical) per remedy pair',
  ],
};
---

<BaseLayout
  title="Data & knowledge-graph export"
  description="Download the full Materia knowledge graph as JSON — every remedy, condition, study, compound, and graded efficacy edge, generated from the content collection."
  jsonld={datasetJsonLd}
>
  <article class="container-x py-14">
    <p class="eyebrow mb-3">Open data</p>
    <h1 class="text-4xl">Data &amp; knowledge-graph export</h1>
    <p class="prose-materia mt-4 text-lg text-muted">
      The entire Materia reference is a knowledge graph: <strong>body → condition →
      remedy → compound → study</strong>, with every remedy×condition edge carrying an
      evidence grade and links to the citations behind it. You can download the whole
      thing as a single JSON file — the same data the site renders, no scraping required.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="/data/materia-graph.json"
        class="btn-primary"
        download
      >
        Download materia-graph.json
      </a>
      <a href="/methodology" class="btn-secondary">Read the methodology</a>
    </div>

    <h2 class="mt-12 text-2xl">What's in the file</h2>
    <p class="prose-materia mt-2 text-fg">
      The graph is a single JSON object with two arrays — <code>nodes</code> and
      <code>edges</code> — plus top-level <code>nodeCount</code>, <code>edgeCount</code>,
      and a <code>generated</code> timestamp. Every node has an <code>id</code> (the
      content-collection slug), a <code>type</code>, and a <code>label</code>.
    </p>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <div class="card p-5">
        <p class="text-3xl font-display font-semibold text-ink">{totalNodes}</p>
        <p class="mt-1 text-sm text-muted">nodes total</p>
      </div>
      <div class="card p-5">
        <p class="text-3xl font-display font-semibold text-ink">{totalEdges}</p>
        <p class="mt-1 text-sm text-muted">edges total</p>
      </div>
      <div class="card p-5">
        <p class="text-3xl font-display font-semibold text-ink">{efficacyEdges}</p>
        <p class="mt-1 text-sm text-muted">graded efficacy claims</p>
      </div>
    </div>

    <h3 class="mt-10 text-xl">Node types</h3>
    <table class="mt-3 w-full text-sm">
      <thead>
        <tr class="text-left text-muted">
          <th class="py-2 pr-4 font-medium">Type</th>
          <th class="py-2 pr-4 font-medium">Count</th>
          <th class="py-2 font-medium">Description</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-line">
        <tr><td class="py-2 pr-4 font-mono">remedy</td><td class="py-2 pr-4">{remedies.length}</td><td class="py-2 text-muted">Herbs, supplements, drugs — each with kind, aliases, safety profile</td></tr>
        <tr><td class="py-2 pr-4 font-mono">condition</td><td class="py-2 pr-4">{conditions.length}</td><td class="py-2 text-muted">Symptoms/disorders with severity, red flags, body-part links</td></tr>
        <tr><td class="py-2 pr-4 font-mono">study</td><td class="py-2 pr-4">{studies.length}</td><td class="py-2 text-muted">Primary research — design, year, sample size, effect, PMID/DOI</td></tr>
        <tr><td class="py-2 pr-4 font-mono">compound</td><td class="py-2 pr-4">{compounds.length}</td><td class="py-2 text-muted">Active constituents with mechanism and biological targets</td></tr>
        <tr><td class="py-2 pr-4 font-mono">source</td><td class="py-2 pr-4">{sources.length}</td><td class="py-2 text-muted">Non-study citations: NCCIH, MedlinePlus, Cochrane, NIH ODS fact sheets</td></tr>
        <tr><td class="py-2 pr-4 font-mono">bodyPart</td><td class="py-2 pr-4">{bodyParts.length}</td><td class="py-2 text-muted">Anatomical regions — the explorer's clickable nodes</td></tr>
      </tbody>
    </table>

    <h3 class="mt-10 text-xl">Edge types</h3>
    <table class="mt-3 w-full text-sm">
      <thead>
        <tr class="text-left text-muted">
          <th class="py-2 pr-4 font-medium">Type</th>
          <th class="py-2 pr-4 font-medium">Count</th>
          <th class="py-2 font-medium">Carries</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-line">
        <tr><td class="py-2 pr-4 font-mono">remedy-treats-condition</td><td class="py-2 pr-4">{efficacyEdges}</td><td class="py-2 text-muted">grade (A–D / insufficient), summary, tradition alignment</td></tr>
        <tr><td class="py-2 pr-4 font-mono">remedy-cites-study</td><td class="py-2 pr-4">{studyCitations}</td><td class="py-2 text-muted">viaCondition — which claim the study supports</td></tr>
        <tr><td class="py-2 pr-4 font-mono">remedy-cites-source</td><td class="py-2 pr-4">{sourceCitations}</td><td class="py-2 text-muted">viaCondition — which claim the source supports</td></tr>
        <tr><td class="py-2 pr-4 font-mono">remedy-contains-compound</td><td class="py-2 pr-4">{compoundEdges}</td><td class="py-2 text-muted">remedy → active constituent</td></tr>
        <tr><td class="py-2 pr-4 font-mono">remedy-interacts-with</td><td class="py-2 pr-4">{interactionEdges}</td><td class="py-2 text-muted">severity, mechanism, optional source ref</td></tr>
        <tr><td class="py-2 pr-4 font-mono">condition-located-at</td><td class="py-2 pr-4">{bodyParts.reduce((n, bp) => n + bp.data.conditions.length, 0)}</td><td class="py-2 text-muted">condition → body part</td></tr>
      </tbody>
    </table>

    <h2 class="mt-12 text-2xl">Using the data</h2>
    <div class="prose-materia mt-2 text-fg">
      <p>
        The file is plain JSON — load it in Python, R, D3, Gephi, or pipe it into an LLM
        context. The <code>schema</code> field (<code>materia-knowledge-graph/v1</code>)
        lets you version-check. Every edge's <code>source</code> and <code>target</code>
        reference node <code>id</code>s that are stable content-collection slugs.
      </p>
      <p>
        Grades follow the scale documented on the
        <a href="/methodology">methodology page</a>: A (strong), B (moderate), C (limited),
        D (weak), insufficient. Grades are assigned <em>per remedy × condition</em> — a
        remedy is never globally "good" or "bad."
      </p>
    </div>

    <div class="mt-8 max-w-2xl rounded-lg border border-line bg-surface p-5 text-sm text-muted">
      <p class="font-medium text-ink">License &amp; attribution</p>
      <p class="mt-2">
        The graph data is released under CC BY 4.0. The underlying study citations point
        to their original publishers (PubMed, journals, NCCIH, etc.) — those sources retain
        their own licenses. Materia is an aggregator; it does not claim ownership of the
        research it references.
      </p>
    </div>
  </article>
</BaseLayout>
