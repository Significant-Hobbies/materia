---
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import '@/styles/global.css';
import Head from '@/components/astro/Head.astro';
import Nav from '@/components/astro/Nav.astro';
import Footer from '@/components/astro/Footer.astro';
import Disclaimer from '@/components/astro/Disclaimer.astro';

interface Props {
  title?: string;
  description?: string;
  bare?: boolean;
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, bare, jsonld } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} bare={bare} jsonld={jsonld} />
  <!-- fleet-jsonld:start (generated by apply-agent-surfaces; edit registry, not this) -->
<script type="application/ld+json">{"@context":"https://schema.org","@graph":[{"@type":"Organization","@id":"https://sassmaker.com/#org","name":"SaaS Maker (Foundry)","url":"https://sassmaker.com","sameAs":["https://sassmaker.com","https://github.com/Significant-Hobbies/materia"]},{"@type":"WebSite","@id":"https://materia.significanthobbies.com/#app","name":"Materia","url":"https://materia.significanthobbies.com","description":"Evidence-graded reference for remedies organized by body part — body → condition → remedy → compound → study, with citations.","publisher":{"@id":"https://sassmaker.com/#org"},"potentialAction":{"@type":"SearchAction","target":"https://materia.significanthobbies.com/?q={search_term_string}","query-input":"required name=search_term_string"}}]}</script>
<!-- fleet-jsonld:end -->
</head>
  <body class="flex min-h-screen flex-col">
    <Disclaimer variant="banner" />
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
