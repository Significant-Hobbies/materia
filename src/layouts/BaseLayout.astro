---
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import '@/styles/global.css';
import Head from '@/components/astro/Head.astro';
import Nav from '@/components/astro/Nav.astro';
import Footer from '@/components/astro/Footer.astro';
import Disclaimer from '@/components/astro/Disclaimer.astro';

interface Props {
  title?: string;
  description?: string;
  bare?: boolean;
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, bare, jsonld } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} bare={bare} jsonld={jsonld} />
  </head>
  <body class="flex min-h-screen flex-col">
    <Disclaimer variant="banner" />
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
